OLLAMA_API_KEY=your_ollama_cloud_api_key
STOCK_RESEARCH_DESK_HOME=~/.stock-research-desk
STOCK_RESEARCH_DESK_MODEL=glm-5.1:cloud
STOCK_RESEARCH_DESK_MODEL_FALLBACKS=glm-5.1:cloud,kimi-k2.5:cloud,qwen3.5:cloud
STOCK_RESEARCH_DESK_THINK=high
STOCK_RESEARCH_DESK_MAX_RESULTS=5
STOCK_RESEARCH_DESK_MAX_FETCHES=6
STOCK_RESEARCH_DESK_TIMEOUT_SECONDS=45
STOCK_RESEARCH_DESK_OLLAMA_HOST=https://ollama.com
STOCK_RESEARCH_DESK_OUTPUT_DIR=reports
STOCK_RESEARCH_DESK_EMAIL_PROVIDER=qq
STOCK_RESEARCH_DESK_EMAIL_ADDRESS=your_mailbox@example.com
STOCK_RESEARCH_DESK_EMAIL_APP_PASSWORD=your_mailbox_app_password
STOCK_RESEARCH_DESK_EMAIL_IMAP_HOST=imap.qq.com
STOCK_RESEARCH_DESK_EMAIL_IMAP_PORT=993
STOCK_RESEARCH_DESK_EMAIL_SMTP_HOST=smtp.qq.com
STOCK_RESEARCH_DESK_EMAIL_SMTP_PORT=465
