#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ -x "${ROOT_DIR}/.venv/bin/python" ]]; then
  export PYTHONPATH="${ROOT_DIR}/src${PYTHONPATH:+:${PYTHONPATH}}"
  exec "${ROOT_DIR}/.venv/bin/python" -c 'import sys; sys.argv[0] = "research-stock"; from stock_research_desk.stock_cli import main; sys.exit(main())' "$@"
fi

export PYTHONPATH="${ROOT_DIR}/src${PYTHONPATH:+:${PYTHONPATH}}"
exec python3 -c 'import sys; sys.argv[0] = "research-stock"; from stock_research_desk.stock_cli import main; sys.exit(main())' "$@"
